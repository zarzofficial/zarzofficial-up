{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://zarzofficial.github.io/zarzofficial-up/",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node -e \"const fs=require('fs');fs.copyFileSync('docs/index.html','docs/404.html');fs.closeSync(fs.openSync('docs/.nojekyll','w'));\"",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');['dist','docs'].forEach((dir)=>fs.rmSync(dir,{recursive:true,force:true}));\"",
    "lint": "tsc --noEmit",
    "predeploy": "npm run build",
    "deploy": "node -e \"console.log('GitHub Pages publishes from main/docs. Push main after build.')\""
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.23",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "react-use": "^17.6.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "gh-pages": "^6.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
